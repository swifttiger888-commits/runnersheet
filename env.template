# Copy to .env.local (gitignored). Defaults below match local demo mode.

# demo — session via demo credentials / quick entry only (no Firebase Auth listeners).
# firebase — Firebase Auth + Firestore users/{uid}.role (requires keys below).
NEXT_PUBLIC_AUTH_PROVIDER=demo

# Firestore collections: journeys, alerts (optional), users/{uid} with:
# role: "driver" | "manager", name, employeeId, homeBranch (e.g. Leeds)

# Firebase Console → Project settings → Your apps → Web app (only when using firebase mode)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server-side API routes such as /api/voice/*)
# Option A: raw JSON from service account key file
# FIREBASE_SERVICE_ACCOUNT_JSON='{"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}'
# Option B: split fields
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# HMAC secret for signed voice links (/api/voice/*)
# VOICE_LINK_SECRET=replace-with-long-random-string

# DeepSeek (server-side only) for manager "Magic Search"
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# Optional override:
# DEEPSEEK_API_ENDPOINT=https://api.deepseek.com/chat/completions
