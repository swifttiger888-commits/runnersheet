# Copy to .env.local and fill in values from Firebase Console → Project settings → Your apps.

# Use "firebase" for production (Auth + Firestore). Use "demo" for local demo only.
# Omit this variable to default to firebase (same as setting firebase).
NEXT_PUBLIC_AUTH_PROVIDER=firebase

# Web app config (Firebase Console → Project settings → General → Your apps → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Canonical URL for SEO (sitemap, Open Graph, JSON-LD). Defaults to https://runnersheet.win if unset.
# NEXT_PUBLIC_SITE_URL=https://runnersheet.win

# Required for Firebase mode: apiKey, authDomain, projectId, appId (storageBucket + messagingSenderId recommended)

# Company-only sign-in: email must end with this domain (e.g. arnoldclark.com). Leave empty for local dev.
# NEXT_PUBLIC_COMPANY_EMAIL_DOMAIN=arnoldclark.com

# Firebase Admin SDK (server-side API routes such as /api/voice/*)
# Option A: raw JSON from service account key file
# FIREBASE_SERVICE_ACCOUNT_JSON='{"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}'
# Option B: split fields
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# HMAC secret for signed voice links (/api/voice/*)
# VOICE_LINK_SECRET=replace-with-long-random-string

# DVLA Vehicle Enquiry Service (server-side only; never expose in NEXT_PUBLIC vars)
# DVLA_API_KEY=
# Optional override (defaults to official endpoint):
# DVLA_API_ENDPOINT=https://driver-vehicle-licensing.api.gov.uk/vehicle-enquiry/v1/vehicles

# DeepSeek (server-side only) for manager "Magic Search" (defaults to deepseek-chat)
# DEEPSEEK_API_KEY=
# Optional: DEEPSEEK_MODEL=deepseek-chat
# Optional override (defaults to official endpoint):
# DEEPSEEK_API_ENDPOINT=https://api.deepseek.com/chat/completions
