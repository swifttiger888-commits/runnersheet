{
  "name": "runnersheet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "NODE_OPTIONS='--max-old-space-size=1024' next dev --webpack -H 127.0.0.1 -p 3000",
    "dev:alt": "NODE_OPTIONS='--max-old-space-size=1024' next dev --webpack -H 127.0.0.1 -p 3005",
    "start": "next start",
    "lint": "eslint",
    "stamp:build": "node scripts/stamp-build-meta.mjs",
    "generate:icons": "node scripts/generate-pwa-icons.mjs",
    "generate:og": "node scripts/generate-og.mjs",
    "preview": "opennextjs-cloudflare build && node scripts/fix-opennext-workers-eval.mjs && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && node scripts/fix-opennext-workers-eval.mjs && opennextjs-cloudflare deploy",
    "deploy:tracked": "npm run stamp:build && opennextjs-cloudflare build && node scripts/fix-opennext-workers-eval.mjs && opennextjs-cloudflare deploy",
    "ship": "npm run deploy",
    "ship:tracked": "npm run deploy:tracked",
    "upload": "opennextjs-cloudflare build && node scripts/fix-opennext-workers-eval.mjs && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "firebase:login": "firebase login",
    "firebase:deploy:firestore": "firebase deploy --only firestore:rules,firestore:indexes"
  },
  "dependencies": {
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "firebase-tools": "^15.11.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.76.0"
  },
  "description": "This is a [Next.js](https://nextjs.org) project bootstrapped with [`create-next-app`](https://nextjs.org/docs/app/api-reference/cli/create-next-app).",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swifttiger888-commits/runnersheet.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/swifttiger888-commits/runnersheet/issues"
  },
  "homepage": "https://github.com/swifttiger888-commits/runnersheet#readme"
}
